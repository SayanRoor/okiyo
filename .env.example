# Variables required for both `pnpm dev` (host) and the docker-compose stack.
#
# Local dev:    copy this to `.env.local`
# Production:   copy this to `.env` (next to docker-compose.yml on the host)
# Vercel:       paste each KEY in Project → Settings → Environment Variables

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Postgres password used by both the postgres container and the web service.
POSTGRES_PASSWORD=please-change-me

# 32-byte hex secret Payload uses to sign sessions and cookies.
# Generate with:  openssl rand -hex 32
PAYLOAD_SECRET=please-change-me

# Public origin used in metadata, OG-tags, password-reset emails and
# in absolute media URLs. Must match the domain users actually visit.
PAYLOAD_PUBLIC_SERVER_URL=https://okiyo.kz

# ---------------------------------------------------------------------------
# REQUIRED — only when running outside docker-compose
# ---------------------------------------------------------------------------

# Connection string used by the Payload Postgres adapter.
# - In docker-compose this is built automatically from POSTGRES_PASSWORD.
# - Local dev with the compose-managed db on host port 5433:
#     DATABASE_URI=postgres://okiyo:${POSTGRES_PASSWORD}@localhost:5433/okiyo
# - On Vercel use a managed Postgres (Neon / Supabase / Vercel Postgres).
DATABASE_URI=

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------

# Override the directory where Payload writes uploaded media.
# Compose mounts ./data/media here — keep as-is unless you know why.
# PAYLOAD_MEDIA_DIR=/var/data/media

# Disable Next.js telemetry. Set to 1 in CI/production, harmless locally.
# NEXT_TELEMETRY_DISABLED=1
