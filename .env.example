# Required for both `pnpm dev` and the docker-compose stack.
# In dev: copy to .env.local; in production: keep as .env next to docker-compose.yml.

# Postgres credentials. Used by the postgres container and the web container.
POSTGRES_PASSWORD=please-change-me

# 32-byte random secret used by Payload to sign sessions.
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=please-change-me

# Public origin used in metadata, links, and password-reset emails.
PAYLOAD_PUBLIC_SERVER_URL=https://okiyo.kz

# DEV-ONLY (point to the host-side dev postgres):
# DATABASE_URI=postgres://okiyo:okiyo@localhost:5433/okiyo
