# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# payload uploads (host-mounted in production)
/media

# payload generated
/src/app/(payload)/admin/importMap.js
/src/payload-types.ts

# reference materials kept locally; not for the deployed repo
/design
/doc

# claude code session state
.claude/

# private project notes (passwords, server creds, AI context)
info_okiyo.md
info_okio.md
